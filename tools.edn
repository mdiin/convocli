 {:name "connection_add",
  :description "Runs `connection add` on the Event Modeling CLI",
  :parameters-schema
  {:type "object",
   :properties
   {"from"
    {:type "number",
     :description "from parameter (ref: elements[].id)"},
    "to"
    {:type "number",
     :description "to parameter (ref: elements[].id)"}},
   :required ["from" "to"]},
  :mapper-source
  (fn
   [args-json]
   (let
    [args (json-parse args-json)]
    (str
     "emcli connection add"
     (apply
      str
      (map
       (fn
        [[k v]]
        (str
         " --"
         (name k)
         " "
         (shell-quote (if (string? v) v (json-encode v)))))
       args)))))}
